{
  "projectType": "api-service",
  "projectName": "GoMoney API",
  "projectDescription": "API de integração externa da GoMoney para gerenciamento de customers e adição de saldo em GMC via PIX.",
  "theme": "luma",
  "primaryColor": "#ef7025",
  "lightColor": "#eec9bc",
  "darkColor": "#4fa1ab",
  "navigation": {
    "tabs": [
      {
        "tab": "Guias",
        "groups": [
          {
            "group": "Introdução",
            "pages": ["welcome", "getting-started"]
          },
          {
            "group": "Conceitos",
            "pages": ["authentication", "customers", "add-balance"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Visão Geral",
