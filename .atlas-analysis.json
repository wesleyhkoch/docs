  "keyFeatures": [
    "Autenticação dual (Bearer JWT + secret-key Base64)",
    "Gerenciamento de customers (criar, listar, atualizar, remover)",
    "Adição de saldo em GMC para customers cadastrados",
    "Consulta de transações por período ou ID",
    "Hierarquia de taxas: customer → user → settings",
    "Rastreabilidade via blockchain (mintHash, approveHash, transferHash)"
  ],
  "publicApiSurface": [
    "POST /users/integration/login",
    "POST /customers",
    "GET /customers/all",
    "PATCH /customers/{customerId}",
    "DELETE /customers/{customerId}",
    "POST /transactions/add-balance",
    "GET /transactions/add-balance/all",
    "GET /transactions/add-balance/{transactionId}"
  ]
}
